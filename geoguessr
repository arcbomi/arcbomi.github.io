(function() {
    'use strict';
    var flag = 0;
    const controlButton = document.createElement('button');
    controlButton.innerHTML = 'Toggle Flag';
    controlButton.style.position = 'fixed';
    controlButton.style.bottom = '20px';
    controlButton.style.right = '20px';
    controlButton.style.zIndex = '9999';

    controlButton.addEventListener('click',
    function() {
        flag = 1 - flag; 
        console.log('Flag value toggled. Current flag:', flag);
    });

    document.body.appendChild(controlButton);
    document.addEventListener('keydown',
    function(event) {
        if (event.key === '1' || event.key === '2') {
            flag = event.key === '1' ? 1 : 0; // 设置 flag 的值为 1 或 0
            console.log('Flag value set to:', flag);
        }
    });


    let previousQuestionId = null;

    function updateStyle() {
        const currentQuestionId = document.querySelector('[data-qa="game-map-header"]').getAttribute('data-current-question-id');
        const targetArea = document.getElementById(currentQuestionId);

        if (currentQuestionId !== previousQuestionId) {
            if (previousQuestionId !== null) {
                const previousArea = document.getElementById(previousQuestionId);
                previousArea.style.removeProperty('--fill-color');
            }
            targetArea.style.setProperty('--fill-color', '#000000');
            previousQuestionId = currentQuestionId;
        }

        if (flag === 1) {
            targetArea.style.setProperty('--fill-color', '#000000');
        } else {
            targetArea.style.removeProperty('--fill-color');
        }
    }

    const intervalId = setInterval(updateStyle, 500);
})();